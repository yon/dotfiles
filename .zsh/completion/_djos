#compdef djos
# Auto-generated by scripts/generate-completion.ts — do not edit by hand.
# Regenerated on every `make build`. To update manually: node scripts/generate-completion.js

_djos() {
  local context state state_descr line
  typeset -A opt_args

  local -a first_level
  first_level=(
    'health:Report DJOS health\: minutes since last successful ingest, queue depth, dead-letter count, and today'\''s LLM spend vs budget.'
    'dashboard:Regenerate the self-contained djos dashboard \(data/dashboard.html\)\: read-only DB queries, Health section \(job staleness, dead-letter breakdown, queue depth\). No LLM calls.'
    'context:Compact briefing for a person\: profile, recent confirmed facts, last interactions, open threads. Accepts a slug, email, or name.'
    'time-analysis:Analyze how meeting time is distributed across work areas and activity types over a window \(default 30 days\).'
    'draft-feedback:Capture draft-vs-sent feedback for DJOS-drafted replies and propose style-guide additions \(written to a .proposed.md for review, never auto-applied\).'
    'ingest:Pull latest code, sync db state, run all ingest pipelines via queue drain loop, export db.'
    'dedup:Recurring dedup pass over the people table \(issue #30\)\: auto-merges the conservative bucket, writes data/dedup-report.md, and leaves the rest for `person merge` / `person distinct`.'
    'digest:Build and write the daily digest \(with health banner\) to the vault, then email it to yon@dowjones.com \(issue #34; disable with DJOS_DIGEST_EMAIL=0\). --resend overrides the once-per-day idempotency guard and sends again.'
    'enrich:Run the person-enrichment batch \(extract new facts for known people\).'
    'prep:Render today'\''s meeting prep notes to the vault, then email them to yon@dowjones.com \(issue #35; disable with DJOS_PREP_EMAIL=0\). Skips the send when there are no meetings. --resend overrides the once-per-day idempotency guard and sends again.'
    'sleep:Run the nightly sleep cycle\: importance backfill, demote_stale, coalesce_buckets, and other quality-loop passes, budget-capped. --dry-run\: writes nothing and makes no LLM calls — coalesce_buckets reports its deterministic bucket plan, every other pass is skipped and reports skippedDryRun.'
    'vault-render:Mark all entities dirty and render the Obsidian vault \(VAULT_DIR, default vault/\).'
    'self-eval:Weekly ground-truth eval\: measure per-tier error rate and auto-tune the tier dial.'
    'ops-report:Build and write the weekly operations report to the vault, then email it to yon@dowjones.com \(issue #36\). --resend overrides the once-per-week idempotency guard and sends again.'
    'cost:summary'
    'email:send-test'
    'person:list, merge, distinct, correct'
    'vip:list, promote, demote, comment, rank'
    'queue:dead, redrive'
    'fact:pin, unpin'
    'task:list, done, drop'
    'job:runs'
  )

  _arguments -C \
    '(-): :->command' \
    '(-)*::arg:->args'

  case $state in
    command)
      _describe 'djos command' first_level
      ;;
    args)
      # Reconstruct the full command name (handles "person list" as two words)
      local cmd_name
      if (( ${#words[@]} >= 2 )); then
        local two_word="${line[1]} ${words[1]}"
        # Check if two-word form is a known command
        case "${line[1]}" in
        cost)
          local -a cost_cmds
          cost_cmds=(
          'summary:LLM cost breakdown by call site. Defaults to last 7 days; pass --days=N to change the window.'
          )
          _describe 'cost command' cost_cmds
          ;;
        email)
          local -a email_cmds
          email_cmds=(
          'send-test:Send a person context email to yourself. Reply-To is the encoded DJOS alias so that replying routes back through the djos_reply classifier.'
          )
          _describe 'email command' email_cmds
          ;;
        person)
          local -a person_cmds
          person_cmds=(
          'list:List people with their fact counts and enrichment status. Provisional stubs are hidden unless --all is passed.'
          'merge:Merge a duplicate person \(loser\) into the canonical one \(winner\)\: repoints facts, emails, meetings, transcripts, aliases; deletes the loser.'
          'distinct:Record that two person slugs are different real people; dedup will never propose merging them again.'
          'correct:Correct a fact about a person\: supersede the prior confirmed fact in that section, record the correction \(which feeds future extraction\), and confirm the new value.'
          )
          _describe 'person command' person_cmds
          ;;
        vip)
          local -a vip_cmds
          vip_cmds=(
          'list:List VIPs, rank-ordered \(1 = highest priority\)\: rank, slug, name, relationship, note, sighting count.'
          'promote:Promote a person to VIP status \(default rank 3 if --rank is omitted\). Resolves --who via slug, then email, then name lookup; never creates a person.'
          'demote:Demote a person from VIP status\: clears vip_rank, vip_note, and vip_since.'
          'comment:Set a person'\''s vip_note\: why they matter, current context.'
          'rank:Change a person'\''s VIP rank \(1 = highest priority\). Also promotes non-VIPs.'
          )
          _describe 'vip command' vip_cmds
          ;;
        queue)
          local -a queue_cmds
          queue_cmds=(
          'dead:List dead-letter queue items \(permanent failure kind, or a retryable kind that failed 8+ times\). Requeue one with QueueStore.reset after fixing the cause.'
          'redrive:Reset dead-letter queue items back to pending \(attempts cleared\), optionally filtered by entity type and capped at a limit. The ongoing counterpart to the one-time dead-letter-triage script\: use once the cause behind a batch of dead rows is fixed.'
          )
          _describe 'queue command' queue_cmds
          ;;
        fact)
          local -a fact_cmds
          fact_cmds=(
          'pin:Pin a fact so it always sorts first on every surface \(context, digest, vault\), regardless of score. Resolves --id as an unambiguous id prefix.'
          'unpin:Unpin a fact, returning it to normal score-ordered display. Resolves --id as an unambiguous id prefix.'
          )
          _describe 'fact command' fact_cmds
          ;;
        task)
          local -a task_cmds
          task_cmds=(
          'list:List open tasks with their ids, so closing one is a single command.'
          'done:Mark a task done, by id or exact title.'
          'drop:Drop a task \(closed, not done\), by id or exact title.'
          )
          _describe 'task command' task_cmds
          ;;
        job)
          local -a job_cmds
          job_cmds=(
          'runs:Pretty-print the last N job runs \(job_runs rows\) with their per-source ingest summaries, backlog snapshots, and errors — inspectable without raw sqlite.'
          )
          _describe 'job command' job_cmds
          ;;
          *)
            # Single-word command — complete its flags
            local full_cmd="${line[1]}"
            case "$full_cmd" in
        'cost summary')
          _arguments \
              '--days=[window in days \(default 7\)]:days:' \
              '(- *)--help[show help]'
          ;;
        'dashboard')
          _arguments \
              '--out=[output path override]:out:' \
              '(- *)--help[show help]'
          ;;
        'context')
          _arguments \
              '--who=[person slug, email, or name]:who:' \
              '(- *)--help[show help]'
          ;;
        'time-analysis')
          _arguments \
              '--days=[window size in days \(default 30\)]:days:' \
              '(- *)--help[show help]'
          ;;
        'email send-test')
          _arguments \
              '--person=[Person slug \(e.g. smith-alice\)]:person:' \
              '(- *)--help[show help]'
          ;;
        'ingest')
          _arguments \
              '--noVault[Skip vault rendering after ingest]' \
              '(- *)--help[show help]'
          ;;
        'person list')
          _arguments \
              '--all[include provisional stubs]' \
              '(- *)--help[show help]'
          ;;
        'person merge')
          _arguments \
              '--loser=[slug to merge away]:loser:' \
              '--winner=[canonical slug to keep]:winner:' \
              '--force[override distinct/frozen guards]' \
              '(- *)--help[show help]'
          ;;
        'person distinct')
          _arguments \
              '--a=[first slug]:a:' \
              '--b=[second slug]:b:' \
              '(- *)--help[show help]'
          ;;
        'person correct')
          _arguments \
              '--slug=[person slug]:slug:' \
              '--section=[fact section \(role, team, title, location, ...\)]:section:' \
              '--text=[corrected value]:text:' \
              '(- *)--help[show help]'
          ;;
        'vip promote')
          _arguments \
              '--who=[person slug, email, or name]:who:' \
              '--rank=[VIP rank, 1 = highest priority \(default 3\)]:rank:' \
              '(- *)--help[show help]'
          ;;
        'vip demote')
          _arguments \
              '--who=[person slug, email, or name]:who:' \
              '(- *)--help[show help]'
          ;;
        'vip comment')
          _arguments \
              '--who=[person slug, email, or name]:who:' \
              '--text=[VIP note text]:text:' \
              '(- *)--help[show help]'
          ;;
        'vip rank')
          _arguments \
              '--who=[person slug, email, or name]:who:' \
              '--rank=[VIP rank, 1 = highest priority]:rank:' \
              '(- *)--help[show help]'
          ;;
        'queue redrive')
          _arguments \
              '--limit=[maximum number of rows to redrive]:limit:' \
              '--type=[restrict to one entity type]:type:' \
              '(- *)--help[show help]'
          ;;
        'fact pin')
          _arguments \
              '--id=[fact id \(or unambiguous prefix\)]:id:' \
              '(- *)--help[show help]'
          ;;
        'fact unpin')
          _arguments \
              '--id=[fact id \(or unambiguous prefix\)]:id:' \
              '(- *)--help[show help]'
          ;;
        'task done')
          _arguments \
              '--id=[task id \(slug\) or exact title]:id:' \
              '(- *)--help[show help]'
          ;;
        'task drop')
          _arguments \
              '--id=[task id \(slug\) or exact title]:id:' \
              '(- *)--help[show help]'
          ;;
        'job runs')
          _arguments \
              '--limit=[number of runs to show, newest first \(default 10, max 200\)]:limit:' \
              '(- *)--help[show help]'
          ;;
        'digest')
          _arguments \
              '--resend[Send again even if today'\''s digest was already sent]' \
              '(- *)--help[show help]'
          ;;
        'prep')
          _arguments \
              '--resend[Send again even if today'\''s prep was already sent]' \
              '(- *)--help[show help]'
          ;;
        'sleep')
          _arguments \
              '--dry-run[write nothing, spend nothing\: coalesce_buckets reports its deterministic bucket plan \(no LLM calls\); all other passes are skipped and report skippedDryRun]' \
              '(- *)--help[show help]'
          ;;
        'ops-report')
          _arguments \
              '--resend[Send again even if this week'\''s report was already sent]' \
              '(- *)--help[show help]'
          ;;
        'health')
          _arguments '(- *)--help[show help]'
          ;;
        'draft-feedback')
          _arguments '(- *)--help[show help]'
          ;;
        'vip list')
          _arguments '(- *)--help[show help]'
          ;;
        'queue dead')
          _arguments '(- *)--help[show help]'
          ;;
        'task list')
          _arguments '(- *)--help[show help]'
          ;;
        'dedup')
          _arguments '(- *)--help[show help]'
          ;;
        'enrich')
          _arguments '(- *)--help[show help]'
          ;;
        'vault-render')
          _arguments '(- *)--help[show help]'
          ;;
        'self-eval')
          _arguments '(- *)--help[show help]'
          ;;
            esac
            ;;
        esac
      fi
      ;;
  esac
}

_djos "$@"
